{
  "name": "admin-panel-backend",
  "version": "2.0.0",
  "description": "Admin Panel Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/config/migrate_master.js",
    "migrate:v1": "node src/config/migrate.js",
    "migrate:v2": "node src/config/migrate_v2.js",
    "seed": "node src/config/seed.js",
    "setup": "npm run migrate && npm run seed",
    "migrate:v3": "node src/config/migrate_v3.js",
    "migrate:all": "node src/config/migrate_all.js",
    "fresh": "npm run migrate:all && npm run seed",
    "migrate:v4": "node src/config/migrate_v4.js",
    "migrate:v5": "node src/config/migrate_v5.js",
    "migrate:v6": "node src/config/migrate_v6.js",
    "migrate:v7": "node src/config/migrate_v7.js",
    "migrate:v8": "node src/config/migrate_v8.js",
    "migrate:v9": "node src/config/migrate_v9.js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true
